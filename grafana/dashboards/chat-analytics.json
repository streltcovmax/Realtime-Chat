                      "queryType": "sql",
                      "rawSql": "WITH toStartOfInterval($__fromTime, INTERVAL 30 seconds) AS from_time, toStartOfInterval($__toTime, INTERVAL 30 seconds) AS to_time SELECT time, ifNull(online_users, 0) AS online_users FROM (SELECT toStartOfInterval(event_time, INTERVAL 30 seconds) AS time, argMax(result_count, event_time) AS online_users FROM chat_analytics.events WHERE event_type = 'user_status_changed' AND event_time <= to_time GROUP BY time ORDER BY time WITH FILL FROM from_time TO to_time STEP INTERVAL 30 seconds INTERPOLATE (online_users)) WHERE time >= from_time AND time <= to_time ORDER BY time ASC"
